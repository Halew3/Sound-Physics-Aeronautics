{
  "schemaVersion": 1,
  "id": "sound_physics_remastered",
  "version": "${mod_version}",
  "name": "Sound Physics Aeronautics (unsupported Fabric source)",
  "description": "Inherited Fabric source for the Sound Physics Aeronautics fork. Public alpha releases target NeoForge 1.21.1 only.",
  "authors": [
    "Sonic Ether",
    "vlad2305m",
    "Max Henkel",
    "Saint",
    "Halew3"
  ],
  "contact": {
    "homepage": "https://github.com/Halew3/Sound-Physics-Aeronautics",
    "issues": "https://github.com/Halew3/Sound-Physics-Aeronautics/issues",
    "sources": "https://github.com/Halew3/Sound-Physics-Aeronautics"
  },
  "license": "GPL",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.sonicether.soundphysics.FabricSoundPhysicsMod"
    ],
    "client": [
      "com.sonicether.soundphysics.FabricSoundPhysicsMod"
    ],
    "modmenu": [
      "com.sonicether.soundphysics.integration.ModMenuIntegration"
    ],
    "voicechat": [
      "com.sonicether.soundphysics.integration.voicechat.SimpleVoiceChatPlugin"
    ]
  },
  "mixins": [
    "sound_physics_remastered.mixins.json"
  ],
  "depends": {
    "fabricloader": "${fabric_loader_dependency}",
    "minecraft": [
      "1.21",
      "1.21.1"
    ],
    "java": ">=${java_version}"
  },
  "breaks": {
    "soundphysics": "*",
    "voicechat": "<1.21-2.3.0"
  },
  "suggests": {
    "modmenu": "*",
    "cloth-config2": ">=${cloth_config_version}",
    "voicechat": ">=${minecraft_version}-${voicechat_api_version}"
  },
  "accessWidener": "sound_physics_remastered.accesswidener"
}
